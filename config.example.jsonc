{
    // ============================================================
    //  lc-agent 配置文件
    //  复制本文件为 config.jsonc，根据需要修改
    // ============================================================
    // ----- UI -----
    "ui": {
        // 网页左上角显示的应用名称，默认 "lc_agent"
        "app_name": "lc_agent"
    },


    // ----- LLM 供应商 -----
    // 支持配置多个供应商，每个供应商可配置多个模型
    // provider 名称随意取，仅用于内部标识
    "provider": {
        "deepseek": {
            // API Key，支持 {env:ENV_VAR_NAME} 语法读取环境变量
            "api_key": "{env:DEEPSEEK_API_KEY}",
            // API 地址（OpenAI 兼容格式）
            "base_url": "https://api.deepseek.com/v1",
            "models": [
                {
                    "id": "deepseek-chat",       // 模型 ID，前端显示和切换用
                    "context_limit": 64000,       // 上下文窗口大小（tokens），对应 LangChain 的 max_input_tokens
                    "max_output_tokens": 65536    // 最大输出 tokens，0 = 不限制
                },
                {
                    "id": "deepseek-reasoner",
                    "context_limit": 64000,
                    "max_output_tokens": 65536
                }
            ]
        }
        // 可以配置多个供应商，如 OpenAI、Anthropic、本地 LiteLLM 等
        // "openai": {
        //     "api_key": "{env:OPENAI_API_KEY}",
        //     "base_url": "https://api.openai.com/v1",
        //     "models": [
        //         {"id": "gpt-4o", "context_limit": 128000, "max_output_tokens": 16384}
        //     ]
        // },
        // "litellm": {
        //     "api_key": "sk-no-key-needed",
        //     "base_url": "http://localhost:4000/v1",
        //     "models": [
        //         {"id": "my-model", "context_limit": 64000, "max_output_tokens": 65536}
        //     ]
        // }
    },

    // ----- Agent 配置 -----
    "agent": {
        // 系统提示词（所有内置预设共用）
        "system_prompt": "你是一个智能助手。请用中文回答。",
        // 默认使用的模型 ID（必须是 provider.models 中已定义的）
        "default_model": "deepseek-chat",
        // 是否启用流式输出
        "streaming": true,
        // LangGraph 最大递归步数（agent 调用工具的最大轮数），默认 100
        "recursion_limit": 100,

        // ----- 上下文摘要（自动压缩对话历史） -----
        // 当对话超过 trigger 阈值时，自动用 LLM 生成旧消息的摘要，
        // 保留最近 keep 范围的消息原文，避免上下文溢出。
        //用户需要懂 from langchain.agents.middleware.summarization import SummarizationMiddleware
        "summarization": {
            // 是否启用自动摘要，默认 true
            "enabled": true,
            // 用于生成摘要的模型 ID（留空则使用当前 agent 的模型）
            // 建议使用便宜/快速的模型，如 deepseek-chat
            "model": "",
            // 触发阈值：达到此阈值时开始压缩
            // 格式: ["fraction", 0.85] — 达到上下文窗口的 85% 时触发
            //       ["tokens", 50000]  — 达到 50000 tokens 时触发
            //       ["messages", 50]   — 达到 50 条消息时触发
            "trigger": ["fraction", 0.85],
            // 保留策略：压缩后保留多少最近的消息
            // 格式: ["fraction", 0.20] — 保留最近 20% 的上下文窗口
            //       ["messages", 20]   — 保留最近 20 条消息
            //       ["tokens", 5000]   — 保留最近 5000 tokens
            "keep": ["fraction", 0.20]
        }
    },

    // ----- 数据库 -----
    "database": {
        // 对话历史存储（SQLAlchemy async URL）
        "url": "sqlite+aiosqlite:///./lc_agent_data.db",
        // LangGraph checkpoint 存储路径
        "checkpoint_path": "./lc_agent_checkpoints.db"
    },

    
    // ----- Skills -----
    // 技能扫描目录列表，支持多个目录
    "skills": ["./skills"],

    // ----- MCP 服务器 -----
    // 支持 local（stdio）、sse、http 三种传输方式
    "mcp_servers": {
        // --- 示例：stdio 本地进程 ---
        // "filesystem": {
        //     "type": "local",
        //     "command": "npx",
        //     "args": ["-y", "@anthropic-ai/mcp-filesystem"],
        //     "env": {},           // 额外环境变量
        //     "enabled": true      // 是否启用，默认 true
        // },

        // --- 示例：SSE 远程服务 ---
        // "remote-search": {
        //     "type": "sse",
        //     "url": "http://localhost:8080/sse",
        //     "enabled": true
        // },

        // --- 示例：Streamable HTTP ---
        // "my-http-mcp": {
        //     "type": "http",
        //     "url": "http://localhost:9090/mcp",
        //     "enabled": true
        // }
    }
}
